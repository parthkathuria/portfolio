---
interface Props {
  id: string;
  title: string; summary: string; problem: string; approach: string;
  architecture: string; impact: string; tags: string[];
  class?: string;
  [key: string]: unknown;
}
const {
  id, title, summary, problem, approach, architecture, impact, tags,
  class: className, ...rest
} = Astro.props;
const hasNote = Astro.slots.has('default');
const dialogId = `proj-${id}`;
const titleId = `${dialogId}-title`;
---
<article class:list={["card", className]} {...rest}>
  <button class="card-btn" type="button" data-open={dialogId} aria-haspopup="dialog">
    <h3>{title}</h3>
    <p class="summary">{summary}</p>
    <ul class="tags">{tags.map((t) => <li>{t}</li>)}</ul>
    <span class="more" aria-hidden="true">Read more →</span>
  </button>
</article>

<dialog id={dialogId} class="project-modal" aria-labelledby={titleId}>
  <div class="modal-inner">
    <button class="modal-close" type="button" data-close aria-label="Close dialog">
      <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <h3 id={titleId}>{title}</h3>
    <p class="m-summary">{summary}</p>
    <ul class="tags">{tags.map((t) => <li>{t}</li>)}</ul>
    <dl>
      <div><dt>Problem</dt><dd>{problem}</dd></div>
      <div><dt>Approach</dt><dd>{approach}</dd></div>
      <div><dt>Architecture</dt><dd>{architecture}</dd></div>
      <div><dt>Impact</dt><dd>{impact}</dd></div>
    </dl>
    {hasNote && <div class="note"><slot /></div>}
  </div>
</dialog>

<style>
  .card {
    border: 1px solid var(--border); border-radius: var(--radius); background: var(--surface);
    box-shadow: var(--shadow); overflow: hidden;
    transition: transform .18s ease, box-shadow .25s ease, border-color .25s ease;
  }
  .card:hover { transform: translateY(-4px); box-shadow: var(--shadow-hover); border-color: var(--border-strong); }
  .card-btn {
    display: block; width: 100%; text-align: left; cursor: pointer;
    background: none; border: 0; color: inherit; font: inherit;
    padding: 1.5rem; border-left: 3px solid transparent; transition: border-color .2s ease;
  }
  .card:hover .card-btn { border-left-color: var(--accent); }
  h3 { margin: 0 0 .4rem; font-size: 1.2rem; }
  .summary { color: var(--muted); margin: 0 0 .9rem; }
  .tags { display: flex; flex-wrap: wrap; gap: .4rem; list-style: none; padding: 0; margin: 0; }
  .tags li {
    font-size: .72rem; font-family: var(--mono); color: var(--accent);
    background: var(--accent-soft); padding: .2rem .55rem; border-radius: 999px;
  }
  .more { display: inline-block; margin-top: 1rem; font-size: .85rem; font-weight: 600; color: var(--accent); }

  /* modal */
  .project-modal {
    width: min(640px, calc(100vw - 2rem)); max-height: 85vh; padding: 0;
    border: 1px solid var(--border-strong); border-radius: var(--radius);
    background: var(--surface); color: var(--fg); box-shadow: var(--shadow-hover);
    overflow: auto;
  }
  .project-modal::backdrop { background: rgba(0,0,0,.6); backdrop-filter: blur(4px); }
  .modal-inner { padding: 2rem; position: relative; }
  .modal-close {
    position: absolute; top: 1rem; right: 1rem; display: grid; place-items: center;
    width: 36px; height: 36px; border-radius: 999px; cursor: pointer;
    background: var(--surface-2); color: var(--muted); border: 1px solid var(--border);
    transition: color .15s ease, border-color .15s ease;
  }
  .modal-close:hover { color: var(--fg); border-color: var(--border-strong); }
  .modal-inner h3 { font-size: 1.5rem; margin: 0 2.5rem .5rem 0; }
  .m-summary { color: var(--muted); margin: 0 0 1rem; }
  dl { margin: 1.5rem 0 0; display: grid; gap: 1.25rem; }
  dt {
    font-size: .72rem; text-transform: uppercase; letter-spacing: .08em;
    color: var(--accent); margin-bottom: .25rem; font-weight: 600;
  }
  dd { margin: 0; color: var(--fg); }
  .note {
    margin-top: 1.5rem; padding: 1rem 1.1rem; border-radius: var(--radius-sm);
    background: var(--surface-2); border: 1px solid var(--border);
    color: var(--muted); font-size: .95rem;
  }
  .note :global(p) { margin: 0; }
  @media (prefers-reduced-motion: no-preference) {
    .project-modal[open] { animation: modal-in .2s cubic-bezier(.16,1,.3,1); }
    @keyframes modal-in { from { opacity: 0; transform: translateY(8px); } }
  }
</style>
