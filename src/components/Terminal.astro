---
// Static terminal window — decorative, monospace engineering flavor.
const lines: Array<{ cmd?: string; out?: string[] }> = [
  { cmd: 'whoami', out: ['Senior Software Engineer · 10+ yrs'] },
  {
    cmd: 'stack --top',
    out: [
      'ai-tooling   MCP · LSP · VSCode Extensions',
      'languages    Java · Go · Python · TypeScript',
      'cloud        AWS · Docker · GraalVM · Jenkins',
    ],
  },
  {
    cmd: 'cat focus.txt',
    out: [
      '"make complex migrations safe and fast,',
      ' and measure quality instead of trusting it."',
    ],
  },
];
---
<div class="term" role="img" aria-label="Terminal showing role, primary tech stack, and engineering focus">
  <div class="bar" aria-hidden="true">
    <span class="dot r"></span><span class="dot y"></span><span class="dot g"></span>
    <span class="title">parth@portfolio — zsh</span>
  </div>
  <div class="body" aria-hidden="true">
    {lines.map((l) => (
      <Fragment>
        <div class="line">
          <span class="prompt">parth@portfolio</span><span class="path"> ~</span> <span class="pct">%</span> <span class="cmd"> {l.cmd}</span>
        </div>
        {l.out?.map((o) => <div class="line out">{o}</div>)}
        <div class="gap"></div>
      </Fragment>
    ))}
    <div class="line">
      <span class="prompt">parth@portfolio</span><span class="path"> ~</span> <span class="pct">%</span> <span class="cursor"> █</span>
    </div>
  </div>
</div>
<style>
  .term {
    border: 1px solid var(--border); border-radius: var(--radius);
    background: #0c0c10; box-shadow: var(--shadow); overflow: hidden;
    font-family: var(--mono);
  }
  .bar {
    display: flex; align-items: center; gap: .5rem;
    padding: .6rem .85rem; border-bottom: 1px solid #1e1e26; background: #15151b;
  }
  .dot { width: 11px; height: 11px; border-radius: 50%; }
  .dot.r { background: #ff5f57; } .dot.y { background: #febc2e; } .dot.g { background: #28c840; }
  .title { margin-left: .5rem; font-size: .78rem; color: #8a8a93; }
  .body { padding: 1.1rem 1.15rem; font-size: .82rem; line-height: 1.6; color: #d7d7df; }
  .line { white-space: pre-wrap; word-break: break-word; }
  .gap { height: .8rem; }
  .prompt { color: #34d399; }
  .path { color: #60a5fa; }
  .pct { color: #8a8a93; }
  .cmd { color: #f5f5f7; }
  .out { color: #a1a1aa; }
  .cursor { color: #34d399; animation: blink 1.1s steps(1) infinite; }
  @keyframes blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) { .cursor { animation: none; } }
</style>
