<button id="theme-toggle" type="button" aria-label="Toggle color theme"><span aria-hidden="true">◐</span></button>
<script>
  import { toggleTheme } from '../scripts/theme';
  document.getElementById('theme-toggle')?.addEventListener('click', () => toggleTheme());
</script>
<style>
  #theme-toggle {
    position: fixed; top: 1rem; right: 1rem; z-index: 5;
    background: var(--fg); color: var(--bg); border: 1px solid var(--fg);
    display: grid; place-items: center;
    border-radius: 999px; width: 2.5rem; height: 2.5rem; font-size: 1.1rem; cursor: pointer;
  }
</style>
