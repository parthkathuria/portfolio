---
import type { SkillGroupData } from '../data/skills';
import SkillIcon from './SkillIcon.astro';
interface Props { group: SkillGroupData; }
const { group } = Astro.props;
---
<div class="group">
  <h3>{group.label}</h3>
  <div class="grid">
    {group.items.map((skill) => <SkillIcon skill={skill} />)}
  </div>
</div>
<style>
  .group { margin-bottom: 2.5rem; }
  h3 {
    font-size: .8rem; text-transform: uppercase; letter-spacing: .08em;
    color: var(--faint); margin: 0 0 1rem; font-weight: 600;
  }
  .grid {
    display: grid; gap: .75rem;
    grid-template-columns: repeat(auto-fill, minmax(96px, 1fr));
  }
</style>
