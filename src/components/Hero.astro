---
import { SITE } from '../config';
import ContactLinks from './ContactLinks.astro';
const metrics = [
  { num: 10, prefix: '', suffix: '+ yrs', label: 'shipping production software' },
  { num: 650, prefix: '', suffix: 'k+', label: 'devices monitored at scale' },
  { num: 15, prefix: '', suffix: '×', label: 'faster clean builds' },
  { num: 20, prefix: '$', suffix: 'k/yr', label: 'infrastructure saved' },
];
---
<section id="top" class="hero">
  <div class="bg" aria-hidden="true"></div>
  <div class="container inner">
    <p class="pill reveal"><span class="dot"></span> Senior Software Engineer · Open to opportunities</p>
    <h1 class="reveal" data-delay="1">
      Hi, I'm {SITE.name}.<br />
      I build distributed systems at scale and <span class="grad">AI-native developer tooling</span>.<span class="caret" aria-hidden="true"></span>
    </h1>
    <p class="tagline reveal" data-delay="2">{SITE.tagline}</p>
    <div class="cta reveal" data-delay="3">
      <a class="btn btn-primary" href="#work">View my work →</a>
      <a class="btn btn-ghost" href={`mailto:${SITE.email}`}>Get in touch</a>
    </div>
    <nav class="socials reveal" data-delay="3" aria-label="Profiles">
      <ContactLinks links="social" />
    </nav>
  </div>
  <div class="container">
    <dl class="metrics reveal">
      {metrics.map((m) => (
        <div class="metric">
          <dt>{m.prefix}<span class="count" data-count-to={m.num}>{m.num}</span>{m.suffix}</dt>
          <dd>{m.label}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>
<style>
  .hero { position: relative; padding-top: calc(var(--nav-h) + 5rem); padding-bottom: 4rem; overflow: hidden; }
  .bg {
    position: absolute; inset: -20% -10% auto -10%; height: 70%; z-index: 0; pointer-events: none;
    background:
      radial-gradient(40% 50% at 20% 20%, rgba(129,140,248,.22), transparent 70%),
      radial-gradient(40% 50% at 80% 10%, rgba(34,211,238,.16), transparent 70%);
    filter: blur(10px);
  }
  .inner { position: relative; z-index: 1; }
  .pill {
    display: inline-flex; align-items: center; gap: .5rem; margin: 0 0 1.5rem;
    padding: .35rem .8rem; border: 1px solid var(--border-strong); border-radius: 999px;
    font-size: .85rem; color: var(--muted); background: var(--surface-2);
  }
  .dot { width: 8px; height: 8px; border-radius: 50%; background: #34d399; box-shadow: 0 0 0 3px rgba(52,211,153,.18); }
  h1 { font-size: clamp(2.5rem, 7vw, 4.75rem); margin: 0 0 1.25rem; max-width: 18ch; }
  .grad {
    background: linear-gradient(120deg, var(--accent) 0%, var(--accent-2) 50%, var(--accent) 100%);
    background-size: 200% 100%;
    -webkit-background-clip: text; background-clip: text; color: transparent;
    animation: grad-shift 7s ease-in-out infinite;
  }
  @keyframes grad-shift { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
  .caret {
    display: inline-block; width: .6ch; height: 1em; margin-left: .12em;
    background: var(--accent); transform: translateY(.12em);
    animation: caret-blink 1.1s steps(1) infinite;
  }
  @keyframes caret-blink { 50% { opacity: 0; } }
  @media (prefers-reduced-motion: reduce) {
    .grad { animation: none; }
    .caret { animation: none; }
  }
  .tagline { font-size: clamp(1.1rem, 2.5vw, 1.35rem); color: var(--muted); max-width: 40rem; margin: 0 0 2rem; }
  .cta { display: flex; flex-wrap: wrap; gap: .75rem; margin-bottom: 1.5rem; }
  .socials { display: flex; gap: 1.25rem; font-size: .95rem; }
  .socials :global(a) { color: var(--muted); }
  .socials :global(a:hover) { color: var(--fg); }
  .metrics {
    margin: 3rem 0 0; padding: 1.5rem 0 0; border-top: 1px solid var(--border);
    display: flex; flex-wrap: wrap; gap: .75rem 2.25rem;
  }
  .metric { display: flex; align-items: baseline; gap: .5rem; }
  .metric dt { font-size: 1rem; font-weight: 700; color: var(--fg); letter-spacing: -.01em; }
  .metric dd { margin: 0; color: var(--muted); font-size: .9rem; }
</style>
