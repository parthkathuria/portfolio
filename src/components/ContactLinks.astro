---
import { siGithub } from 'simple-icons';
import { SITE, SHOW_RESUME, RESUME_PATH } from '../config';
interface Props {
  emailAsAddress?: boolean;
  /** 'all' = email + socials (+ résumé if enabled); 'social' = LinkedIn + GitHub only. */
  links?: 'all' | 'social';
}
const { emailAsAddress = false, links = 'all' } = Astro.props;
const showEmail = links === 'all';
// LinkedIn is not in simple-icons (trademark-removed); inline the glyph.
const linkedinPath =
  'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z';
---
{showEmail && <a href={`mailto:${SITE.email}`}>{emailAsAddress ? SITE.email : 'Email'}</a>}
<a href={SITE.linkedin} rel="noopener noreferrer" target="_blank">
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={linkedinPath} /></svg>
  LinkedIn
</a>
<a href={SITE.github} rel="noopener noreferrer" target="_blank">
  <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={siGithub.path} /></svg>
  GitHub
</a>
{showEmail && SHOW_RESUME && <a href={RESUME_PATH}>Résumé (PDF)</a>}
<style>
  a { display: inline-flex; align-items: center; gap: .4rem; }
  svg { width: 1.05em; height: 1.05em; flex-shrink: 0; }
</style>
