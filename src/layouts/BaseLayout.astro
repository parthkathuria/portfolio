---
import '../styles/global.css';
import { SITE, CANONICAL_ORIGIN } from '../config';
interface Props { title?: string; }
const { title = `${SITE.name} — ${SITE.title}` } = Astro.props;
// Single-page site: canonical/OG always point at the primary (Cloudflare) origin
// so the GitHub Pages mirror dedupes to one URL in search.
const canonical = `${CANONICAL_ORIGIN}/`;
const ogImage = `${CANONICAL_ORIGIN}/og.png?v=3`;
// Base-prefixed so assets resolve on the GitHub Pages subpath (/portfolio) too.
const base = import.meta.env.BASE_URL;
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.name,
  jobTitle: SITE.title,
  url: CANONICAL_ORIGIN,
  sameAs: [SITE.linkedin, SITE.github],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}favicon.png`} />
    <title>{title}</title>
    <meta name="description" content={SITE.description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={SITE.description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={SITE.description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    <!-- Theme bootstrap: runs before paint to avoid flash of wrong theme -->
    <script is:inline>
      (function () {
        try {
          var s = localStorage.getItem('theme');
          var t = (s === 'light' || s === 'dark') ? s : 'dark';
          document.documentElement.setAttribute('data-theme', t);
          document.documentElement.classList.add('js');
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <slot />
  </body>
</html>
