---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import WorkCard from '../components/WorkCard.astro';
import SkillGroup from '../components/SkillGroup.astro';
import ContactLinks from '../components/ContactLinks.astro';
import Footer from '../components/Footer.astro';
import { SKILLS } from '../data/skills';
import { ALSO_SHIPPED } from '../data/alsoShipped';
import { SITE, SHOW_OSS } from '../config';

const entries = (await getCollection('work', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);
const work = await Promise.all(
  entries.map(async (entry) => ({
    id: entry.slug,
    data: entry.data,
    Content: (await entry.render()).Content,
  }))
);

const COMPANY_META: Record<string, string> = {
  Intuit: 'Senior Software Engineer · 2021–Present',
  'NEXTracker (NEXTPower), Inc': 'Software Development Engineer · 2016–2021',
};

// Group projects by company, preserving order (Intuit first, then NEXTracker).
const byCompany: { company: string; items: typeof work }[] = [];
for (const w of work) {
  let group = byCompany.find((g) => g.company === w.data.company);
  if (!group) {
    group = { company: w.data.company, items: [] };
    byCompany.push(group);
  }
  group.items.push(w);
}
---
<BaseLayout>
  <Nav />
  <Hero />
  <main id="main">
    <section id="work">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow"><span class="num">01</span>Projects</span>
          <h2>Things I've built.</h2>
          <p class="lead">Projects I worked on or led across AI-native tooling, language infrastructure, and distributed systems at scale. Tap any tile to expand the details.</p>
        </div>
        {byCompany.map((group) => (
          <div class="company">
            <div class="company-head reveal">
              <h3 class="company-name">{group.company}</h3>
              <span class="company-meta">{COMPANY_META[group.company]}</span>
            </div>
            <div class="work-grid">
              {group.items.map((w, i) => (
                <WorkCard
                  class="reveal"
                  data-delay={(i % 2) + 1}
                  id={w.id}
                  title={w.data.title}
                  summary={w.data.summary}
                  problem={w.data.problem}
                  approach={w.data.approach}
                  architecture={w.data.architecture}
                  impact={w.data.impact}
                  tags={w.data.tags}
                >
                  <w.Content />
                </WorkCard>
              ))}
            </div>
          </div>
        ))}

        <div class="also reveal">
          <h3 class="also-head">Also shipped</h3>
          <ul class="also-list">
            {ALSO_SHIPPED.map((item) => (
              <li>
                <div class="also-top">
                  <span class="also-title">{item.title}</span>
                  <span class="also-company">{item.company}</span>
                  <span class="also-tag">{item.tag}</span>
                </div>
                <p class="also-detail">{item.detail}</p>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <section id="skills" class="alt">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow"><span class="num">02</span>Toolbox</span>
          <h2>Skills &amp; technologies.</h2>
          <p class="lead">A decade across languages, AI tooling, cloud platforms, and data systems.</p>
        </div>
        <div class="reveal">
          {SKILLS.map((g) => <SkillGroup group={g} />)}
        </div>
      </div>
    </section>

    <section id="about">
      <div class="container">
        <div class="section-head reveal">
          <span class="eyebrow"><span class="num">03</span>About</span>
          <h2>About me.</h2>
        </div>
        <div class="about-body reveal" data-delay="1">
          <p>
            I'm a software engineer with a proven history of leading
            platform modernization, defining technical direction, and building
            high-impact developer tooling across organization-wide programs. My
            focus is making complex migrations safe and fast — pairing
            deterministic engineering with AI where it earns its place, and
            measuring quality instead of trusting it.
          </p>
          <p class="muted">
            My work spans agentic AI pipeline design, AI-ready language
            architectures with LSP integration, distributed data pipelines, and
            event-driven microservices on AWS.
          </p>
        </div>
      </div>
    </section>

    {SHOW_OSS && (
      <section id="oss" class="alt">
        <div class="container">
          <div class="section-head reveal">
            <span class="eyebrow">Open Source</span>
            <h2>Public projects.</h2>
            <p class="lead">Selected open-source work — coming soon.</p>
          </div>
        </div>
      </section>
    )}

    <section id="contact" class="alt">
      <div class="container contact reveal">
        <span class="eyebrow"><span class="num">04</span>Contact</span>
        <h2>Let's build something.</h2>
        <p class="lead">Open to senior and staff engineering roles across distributed systems, AI infrastructure, developer tooling, and platforms.</p>
        <div class="contact-cta">
          <a class="btn btn-primary" href={`mailto:${SITE.email}`}>{SITE.email}</a>
        </div>
        <nav class="contact-socials" aria-label="Profiles">
          <ContactLinks links="social" />
        </nav>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  import { toggleTheme } from '../scripts/theme';
  import { initReveal, initScrollSpy } from '../scripts/reveal';
  import { initModals } from '../scripts/modal';
  import { initCountUp, initCardGlow } from '../scripts/effects';
  document.getElementById('theme-toggle')?.addEventListener('click', () => toggleTheme());
  initReveal();
  initScrollSpy();
  initModals();
  initCountUp();
  initCardGlow();
</script>

<style>
  .company { margin-bottom: 3rem; }
  .company:last-of-type { margin-bottom: 0; }
  .company-head {
    display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap;
    margin-bottom: 1.25rem; padding-bottom: .6rem; border-bottom: 1px solid var(--border);
  }
  .company-name { font-size: 1.15rem; margin: 0; }
  .company-meta { font-family: var(--mono); font-size: .8rem; color: var(--faint); }

  /* masonry via CSS multi-column — tiles of varying height pack with no gaps */
  .work-grid { columns: 2; column-gap: 1.25rem; }
  .work-grid > :global(.card) { break-inside: avoid; margin: 0 0 1.25rem; width: 100%; }

  .also { margin-top: 3.5rem; padding-top: 2rem; border-top: 1px solid var(--border); }
  .also-head { font-size: .8rem; text-transform: uppercase; letter-spacing: .08em; color: var(--faint); font-weight: 600; margin: 0 0 1.25rem; }
  .also-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 1.25rem; }
  .also-top { display: flex; align-items: baseline; gap: .75rem; flex-wrap: wrap; }
  .also-title { font-weight: 600; font-size: 1.02rem; }
  .also-tag { font-family: var(--mono); font-size: .68rem; color: var(--accent); background: var(--accent-soft); padding: .15rem .5rem; border-radius: 999px; }
  .also-company { font-family: var(--mono); font-size: .68rem; color: var(--muted); border: 1px solid var(--border-strong); padding: .15rem .5rem; border-radius: 999px; }
  .also-detail { color: var(--muted); margin: .3rem 0 0; font-size: .95rem; }

  .about-body { max-width: var(--maxw-read); }
  .about-body p { font-size: 1.2rem; margin-top: 0; }
  .about-body p:last-child { margin-bottom: 0; }
  .contact { text-align: center; max-width: 40rem; margin-inline: auto; }
  .contact .eyebrow { color: var(--accent); }
  .contact-cta { margin: 1.5rem 0 1rem; }
  .contact-socials { display: flex; gap: 1.25rem; justify-content: center; }
  .contact-socials :global(a) { color: var(--muted); }
  .contact-socials :global(a:hover) { color: var(--fg); }
  @media (max-width: 860px) {
    .work-grid { columns: 1; }
  }
</style>
